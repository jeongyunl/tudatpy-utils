---
config:
  flowchart:
    curve: basis
---
%% Data Flow Diagram of Executable Python Scripts
%% Shows how scripts connect through shared data formats (input → script → output)
%%
%% Legend:
%%   Rounded rectangles ([...]) = executable scripts
%%   Hexagons {{...}} = data formats
%%   Arrows show data flow direction with format labels

flowchart LR

    %% ===== Data Format Nodes =====
    fmt_tle{{"TLE (.tle)"}}
    fmt_omm{{"OMM (.omm)"}}
    fmt_oem{{"OEM / State Vectors <br/> (CCSDS OEM or simple format: epoch x y z vx vy vz)"}}
    fmt_kepler{{"OEM-like Keplerian Elements <br/> (epoch a e i ω Ω θ)"}}
    fmt_dep_vars_csv{{"Dependent Variables CSV"}}
    fmt_plots{{"Plots / Animations <br/> (Matplotlib figures)"}}
    fmt_time{{"Time Values <br/> (ISO / POSIX / UTC / TAI / TT / TDB)"}}
    fmt_celestrak{{"CelesTrak<br/>(HTTP download)"}}

    %% ===== Script Nodes =====

    %% bin/ scripts
    download_tle(["download_tle.py"])
    omm_to_tle(["omm_to_tle.py"])
    tle_to_omm(["tle_to_omm.py"])
    tle_info(["tle_info.py"])

    %% oem_to_omm/ scripts
    oem_to_omm(["oem_to_omm.py"])

    %% propagation/ scripts
    propagate_tle(["propagate_tle.py"])
    propagate_sat(["propagate_orbit.py"])
    propagate_kepler(["propagate_kepler.py"])
    plot_dep_vars(["plot_dependent_variables.py"])
    plot_orbits(["plot_orbits.py"])

    %% conversion/ utilities
    slice_oem(["slice_oem.py"])
    state_diff(["state_diff.py"])

    %% frame_conversion/ scripts
    gcrf_to_itrf_rot(["gcrf_to_itrf_rot_model.py"])
    gcrf_to_itrf_spice(["gcrf_to_itrf_spice.py"])

    %% time_conversion/tools/ scripts
    convert_time(["convert_time.py"])
    convert_time2(["convert_time2.py"])

    %% oem_to_omm/ evaluation scripts
    evaluate_fit_tle(["evaluate_fit_tle.py"])

    %% ===== Data Flows =====

    %% download_tle.py: CelesTrak → TLE or OMM files
    fmt_celestrak -->|"satellite ID"| download_tle
    download_tle -->|"TLE format"| fmt_tle
    download_tle -->|"OMM format"| fmt_omm

    %% oem_to_omm.py: OEM state vectors → OMM (Keplerian or TLE)
    fmt_oem --> oem_to_omm
    oem_to_omm --> fmt_omm
    oem_to_omm --> fmt_tle

    %% omm_to_tle.py: OMM → TLE
    fmt_omm --> omm_to_tle
    omm_to_tle --> fmt_tle

    %% tle_to_omm.py: TLE → OMM
    fmt_tle --> tle_to_omm
    tle_to_omm --> fmt_omm

    %% tle_info.py: TLE → console summary
    fmt_tle --> tle_info

    %% propagate_tle.py: TLE → OEM-like state vectors
    fmt_tle --> propagate_tle
    propagate_tle --> fmt_oem

    %% propagate_orbit.py: single OEM state line → propagated outputs
    fmt_oem -->|"single state line"| propagate_sat
    propagate_sat -->|"state history"| fmt_oem
    propagate_sat -->|"dependent variables"| fmt_dep_vars_csv

    %% propagate_kepler.py: Keplerian elements → OEM state vectors
    fmt_kepler --> propagate_kepler
    propagate_kepler --> fmt_oem

    %% plot_orbits.py: OEM state files → plots
    fmt_oem --> plot_orbits
    plot_orbits --> fmt_plots

    %% slice_oem.py: OEM → sliced OEM states
    fmt_oem --> slice_oem
    slice_oem --> fmt_oem

    %% state_diff.py: OEM state vectors → comparison summary
    fmt_oem --> state_diff

    %% plot_dependent_variables.py: dependent-variable CSV → plots/animations
    fmt_dep_vars_csv --> plot_dep_vars
    plot_dep_vars --> fmt_plots

    %% gcrf_to_itrf_rot_model.py: OEM (GCRF↔ITRF)
    fmt_oem -->|"GCRF or ITRF"| gcrf_to_itrf_rot
    gcrf_to_itrf_rot -->|"ITRF or GCRF"| fmt_oem

    %% gcrf_to_itrf_spice.py: OEM (J2000↔ITRF93)
    fmt_oem -->|"J2000 or ITRF93"| gcrf_to_itrf_spice
    gcrf_to_itrf_spice -->|"ITRF93 or J2000"| fmt_oem

    %% convert_time.py: time values → converted time values
    fmt_time --> convert_time
    convert_time --> fmt_time

    %% convert_time2.py: time values → converted time values
    fmt_time --> convert_time2
    convert_time2 --> fmt_time

    %% evaluate_fit_tle.py: OEM → fit TLE → propagate TLE → comparison
    fmt_oem --> evaluate_fit_tle
    evaluate_fit_tle -->|"uses"| oem_to_omm
    evaluate_fit_tle -->|"uses"| propagate_tle
