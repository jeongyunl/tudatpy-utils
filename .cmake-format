format:
  # Maximum number of characters allowed on each line.
  # Default: 80
  line_width: 79
  # Number of spaces that a tab is treated as equivalent to for indentation
  # purposes.
  # Default: 2
  tab_size: 4
  # If an argument group contains more than this many sub-groups (positional or
  # keyword wargument groups) then force it to a vertical layout.
  # Default: 2
  max_subgroups_hwrap: 2
  # If a positional argument group contains more than this many arguments, then
  # force it to a vertical layout.
  # Default: 6
  max_pargs_hwrap: 2
  # If a cmdline positional group consumes more than this many lines without
  # nesting, then invalidate the layout (and nest).
  # Default: 2
  max_rows_cmdline: 2
  # If true, separate flow control names from their parentheses with a space.
  # Default: false
  separate_ctrl_name_with_space: false
  # If true, separate function names from parentheses with a space.
  # Default: false
  separate_fn_name_with_space: false
  # If a statement is wrapped to more than one line, than dangle the closing
  # parenthesis on its own line.
  # Default: false
  dangle_parens: true
  # If the trailing parenthesis must be 'dangled' on its on line, then align
  # it to this reference:
  #   prefix: the start of the statement
  #   prefix-indent: the start of the statement, plus one indentation level
  #   child: align to the column of the arguments
  # Default: prefix
  dangle_align: prefix
  # If the statement spelling length (including space and parenthesis) is
  # smaller than this amount, then force reject nested layouts.
  # Default: 4
  min_prefix_chars: 4
  # If the statement spelling length (including space and parenthesis) is
  # larger than the tab width by more than this amount, then force reject
  # un-nested layouts.
  # Default: 10
  max_prefix_chars: 10
  # If a candidate layout is wrapped horizontally but it exceeds this many
  # lines, then reject the layout.
  # Default: 2
  max_lines_hwrap: 2
  # What style line endings to use in the output.
  # Default: unix
  line_ending: unix
  # Format command names consistently as 'lower' or 'upper' case.
  # Default: canonical
  command_case: canonical
  # Format keywords consistently as 'lower' or 'upper' case.
  # Default: unchanged
  keyword_case: unchanged
  # A list of command names which should always be wrapped
  # Default: []
  always_wrap: []
  # If true, the argument lists which are known to be sortable will be sorted
  # lexicographicall.
  # Default: true
  enable_sort: true
  # If true, the parsers may infer whether or not an argument list is sortable
  # (without annotation).
  # Default: false
  autosort: false
  # By default, if cmake-format cannot successfully fit everything into the
  # desired linewidth it will apply the last, most aggressive attempt that it
  # made. If this flag is True, however, cmake-format will print error, exit
  # with non- zero status code, and write-out nothing.
  # Default: false
  require_valid_layout: false
  # A dictionary mapping layout nodes to a list of wrap decisions. See the
  # documentation for more information.
  # Default: {}
  layout_passes: {}
markup:
  # Enable comment markup parsing and reflow
  # Default: true
  enable_markup: true
  # What character to use for bulleted lists
  # Default: '*'
  bullet_char: '*'
  # What character to use as punctuation after numerals in an enumerated list.
  # Default: .
  enum_char: .
  # If comment markup is enabled, don't reflow the first comment block in each
  # listfile. Use this to preserve formatting of your copyright/license
  # statements.
  # Default: false
  first_comment_is_literal: true
  # If comment markup is enabled, don't reflow any comment block which matches
  # this (regex) pattern. Default is `None` (disabled).
  # Default: null
  literal_comment_pattern: null
  # Regular expression to match preformat fences in comments
  # Default: ^\s*([`~]{3}[`~]*)(.*)$
  fence_pattern: ^\s*([`~]{3}[`~]*)(.*)$
  # Regular expression to match rulers in comments
  # Default: ^\s*[^\w\s]{3}.*[^\w\s]{3}$
  ruler_pattern: ^\s*[^\w\s]{3}.*[^\w\s]{3}$
  # If a comment line matches starts with this pattern then it is explicitly a
  # trailing comment for the preceding argument.
  # Default: '#<'
  explicit_trailing_pattern: '#<'
  # If a comment line starts with at least this many consecutive hash
  # characters, then don't lstrip() them off. This allows for lazy hash rulers
  # where the first hash char is not separated by space.
  # Default: 10
  hashruler_min_length: 10
  # If true, then insert a space between the first hash char and remaining hash
  # chars in a hash ruler, and normalize its length to fill the column.
  # Default: true
  canonicalize_hashrulers: true
lint:
  # a list of lint codes to disable
  # Default: []
  disabled_codes: []
  # regular expression pattern describing valid function names
  # Default: '[0-9a-z_]+'
  function_pattern: '[0-9a-z_]+'
  # regular expression pattern describing valid macro names
  # Default: '[0-9A-Z_]+'
  macro_pattern: '[0-9A-Z_]+'
  # regular expression pattern describing valid names for variables with global
  # (cache) scope
  # Default: '[A-Z][0-9A-Z_]+'
  global_var_pattern: '[A-Z][0-9A-Z_]+'
  # regular expression pattern describing valid names for variables with global
  # scope (but internal semantic)
  # Default: _[A-Z][0-9A-Z_]+
  internal_var_pattern: _[A-Z][0-9A-Z_]+
  # regular expression pattern describing valid names for variables with local
  # scope
  # Default: '[a-z][a-z0-9_]+'
  local_var_pattern: '[a-z][a-z0-9_]+'
  # regular expression pattern describing valid names for privatedirectory
  # variables
  # Default: _[0-9a-z_]+
  private_var_pattern: _[0-9a-z_]+
  # regular expression pattern describing valid names for public directory
  # variables
  # Default: '[A-Z][0-9A-Z_]+'
  public_var_pattern: '[A-Z][0-9A-Z_]+'
  # regular expression pattern describing valid names for function/macro
  # arguments and loop variables.
  # Default: '[a-z][a-z0-9_]+'
  argument_var_pattern: '[a-z][a-z0-9_]+'
  # regular expression pattern describing valid names for keywords used in
  # functions or macros
  # Default: '[A-Z][0-9A-Z_]+'
  keyword_pattern: '[A-Z][0-9A-Z_]+'
  # In the heuristic for C0201, how many conditionals to match within a loop in
  # before considering the loop a parser.
  # Default: 2
  max_conditionals_custom_parser: 2
  # Require at least this many newlines between statements
  # Default: 1
  min_statement_spacing: 1
  # Require no more than this many newlines between statements
  # Default: 2
  max_statement_spacing: 2
  # Default: 6
  max_returns: 6
  # Default: 12
  max_branches: 12
  # Default: 5
  max_arguments: 5
  # Default: 15
  max_localvars: 15
  # Default: 50
  max_statements: 50
encode:
  # If true, emit the unicode byte-order mark (BOM) at the start of the file
  # Default: false
  emit_byteorder_mark: false
  # Specify the encoding of the input file. Defaults to utf-8
  # Default: utf-8
  input_encoding: utf-8
  # Specify the encoding of the output file. Defaults to utf-8. Note that CMake
  # only claims to support utf-8 so be careful when using anything else
  # Default: utf-8
  output_encoding: utf-8
